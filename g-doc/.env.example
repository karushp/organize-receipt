# Copy to .env and fill in your values. Do not commit .env.

# ---------- Option A: OAuth (personal Google account) – use this for My Drive ----------
# No Shared Drive or Workspace needed. Create OAuth client in Google Cloud Console:
# APIs & Services → Credentials → Create OAuth client ID (Web application).
# Add redirect URI: http://localhost:8501  Enable: Drive API, Sheets API.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8501

# ---------- Option B: Service account (Workspace / Shared Drives only) ----------
# GOOGLE_APPLICATION_CREDENTIALS=private/credentials.json

# ---------- Users ----------
# For each user: {USER}_SHEET_ID (required), {USER}_DRIVE_FOLDER_ID (required for OAuth), optional {USER}_EMAIL
USERS=
# Example: USERS=KP
# KP_SHEET_ID=...   KP_DRIVE_FOLDER_ID=...   KP_EMAIL=you@gmail.com (optional for SA sharing)

# ---------- Categories ----------
CATEGORIES=
# Example: CATEGORIES=Food,Transportation,Entertainment,Utilities,Shopping
