# Copy to .env and fill in your values. Do not commit .env.

# Option A: Path to Google service account JSON key (leave empty if using Option B)
# GOOGLE_APPLICATION_CREDENTIALS=private/credentials.json

# Option B: Paste service account fields from your JSON key (no key file needed)
GCP_PROJECT_ID=
GCP_PRIVATE_KEY_ID=
GCP_PRIVATE_KEY=
GCP_CLIENT_EMAIL=
# GCP_CLIENT_ID=   # optional
# Private key: one line, use \n for newlines (from JSON "private_key")

# Users (comma-separated). For each user set {USER}_SHEET_ID and {USER}_DRIVE_FOLDER_ID
USERS=
# Example: USERS=user-01,user-02
# Then set: user-01_SHEET_ID=, user-01_DRIVE_FOLDER_ID=, user-02_SHEET_ID=, user-02_DRIVE_FOLDER_ID=

# Categories (comma-separated)
CATEGORIES=
# Example: CATEGORIES=Food,Transportation,Entertainment,Utilities,Shopping
